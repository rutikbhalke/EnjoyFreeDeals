{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!assets/|favicon.ico|logo.png|og-image.png|placeholder.svg|robots.txt|llms.txt|sitemap.xml).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/scrape-telegram",
      "schedule": "0 3 * * *"
    }
  ]
}

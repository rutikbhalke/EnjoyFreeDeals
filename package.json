{
  "name": "enjoy-free-deals-backend",
  "version": "1.0.0",
  "description": "Backend API for EnjoyFreeDeals using Supabase server-side access.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "check": "node --check src/server.js",
    "check:deploy": "node --check src/server.js && node --check api/index.js && node --check scripts/sync-genie-loot.js",
    "sync:genie-loot": "node scripts/sync-genie-loot.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart enjoyfreedeals-api",
    "vercel:deploy": "npx vercel --prod"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  }
}

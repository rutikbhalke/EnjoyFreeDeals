SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_PROJECT_ID=your_project_ref_here
PORT=5000

# Supabase Edge Function secret for the hourly deal importer.
# Set this with `supabase secrets set`, not in Android.
IMPORT_DEALS_CRON_SECRET=your_random_import_secret_here

# Android build-time config. This is a public OAuth client ID, not a secret.
GOOGLE_WEB_CLIENT_ID=your_google_web_oauth_client_id.apps.googleusercontent.com

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=
BACKEND_BASE_URL=https://enjoyfreedeals.vercel.app
PORT=5000
APP_ENV=production

# Supabase Edge Function secret for the hourly deal importer.
# Set this with `supabase secrets set`, not in Android.
IMPORT_DEALS_CRON_SECRET=your_random_import_secret_here

# Telegram Bot API token for server-side channel imports.
# Keep this out of Android and committed source. If a token is shared publicly,
# rotate it in BotFather and set the new value as a Supabase Edge Function secret.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_DEFAULT_IMAGE_URL=
TELEGRAM_IMPORT_SECRET=
GENIE_LOOT_PAGE_URL=https://t.me/s/India_loot_deals
GENIE_LOOT_PAGE_URLS=https://t.me/s/India_loot_deals,https://t.me/s/king_deal_1,https://t.me/s/icoolzTricks
GENIE_LOOT_BEST_DEAL_FRACTION=0.3
GENIE_LOOT_MAX_PAGES=25
GENIE_LOOT_CHEAP_PRICE_LIMIT=999
GENIE_LOOT_REJECT_UNSELECTED=true
GENIE_LOOT_STALE_SCAN_LIMIT=5000
TELEGRAM_PAGE_FETCH_TIMEOUT_MS=15000
TELEGRAM_EXPIRY_DAYS=1

# WhatsApp OTP login through MyOperator.
# Keep the auth token on the backend only. Do not put it in Android build config.
MYOPERATOR_BASE_URL=https://publicapi.myoperator.co
MYOPERATOR_SEND_PATH=/chat/messages
MYOPERATOR_API_TOKEN=
MYOPERATOR_COMPANY_ID=
MYOPERATOR_PHONE_NUMBER_ID=
MYOPERATOR_TEMPLATE_ID=
MYOPERATOR_WHATSAPP_TEMPLATE_NAME=otp_verify
MYOPERATOR_WHATSAPP_WABA_ID=
MYOPERATOR_WHATSAPP_BUSINESS_NAME=
MYOPERATOR_WHATSAPP_BUSINESS_PHONE=
MYOPERATOR_WHATSAPP_TEMPLATE_LANGUAGE=en
MYOPERATOR_WHATSAPP_DEV_MODE=false
USE_TEST_OTP=true
TEST_OTP=123456
WHATSAPP_OTP_SECRET=
WHATSAPP_OTP_PASSWORD_SECRET=
WHATSAPP_OTP_TTL_SECONDS=300
WHATSAPP_OTP_RESEND_SECONDS=45
WHATSAPP_OTP_MAX_ATTEMPTS=5
